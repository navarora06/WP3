SECRET_KEY=dev-secret-change-me
DATABASE_URL=postgresql+psycopg2://tacitgap:tacitgap@db:5432/tacitgap
REDIS_URL=redis://redis:6379/0

STORAGE_ROOT=/app/storage

# ---- Azure AI Foundry (OpenAI) ----
AZURE_AI_ENDPOINT=https://<your-project>.services.ai.azure.com
AZURE_AI_PROJECT_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_NLI_DEPLOYMENT=gpt-4o

# ---- Azure Speech (transcription) ----
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=swedencentral

# ---- Azure Translator (FI->EN) ----
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
AZURE_TRANSLATOR_REGION=swedencentral

# ---- Azure OpenAI Embeddings (Create Knowledge) ----
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# ---- Azure AI Search (vector store for RAG) ----
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_KEY=

# ---- Azure Cosmos DB Gremlin (knowledge graph) ----
AZURE_COSMOS_GREMLIN_ENDPOINT=wss://<your-cosmos>.gremlin.cosmos.azure.com:443/
AZURE_COSMOS_GREMLIN_KEY=
AZURE_COSMOS_GREMLIN_DATABASE=wp3knowledge
AZURE_COSMOS_GREMLIN_GRAPH=knowledge_graph

# ---- Azure AI Vision (multimodal embeddings for images) ----
AZURE_VISION_ENDPOINT=https://<your-vision>.cognitiveservices.azure.com/
AZURE_VISION_KEY=
